{
  "manifest_version": 3,
  "name": "OpenSidekick — Bring-Your-Own-LLM Browser Agent",
  "short_name": "OpenSidekick",
  "version": "0.1.0",
  "description": "Open-source, provider-agnostic AI assistant that reads and acts on web pages. Use any LLM: OpenRouter, OpenAI, Anthropic, Google, Groq, or a local model.",
  "author": "OpenSidekick contributors",
  "homepage_url": "https://github.com/esterhuizen/opensidekick",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open OpenSidekick (Ctrl+E / Cmd+E)",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content-script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "sidePanel",
    "storage",
    "scripting",
    "tabs",
    "activeTab",
    "contextMenus",
    "notifications",
    "debugger"
  ],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+E",
        "mac": "Command+E"
      },
      "description": "Open the OpenSidekick side panel"
    }
  }
}
